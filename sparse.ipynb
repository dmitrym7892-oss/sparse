class RealDataLoader:
    def __init__(self, data_dir: Path = DATA_DIR):
        self.data_dir = data_dir
        self.stock_data = None
        self.volatility_data = None
        self.correlation_matrix = None
        
    def download_sp500_stocks(self, limit: int = 30, period: str = "2y") -> pd.DataFrame:
        print(f"Loading S&P 500 data ({limit} stocks, period: {period})...")
        
        symbols = [
            'AAPL', 'MSFT', 'GOOGL', 'AMZN', 'NVDA', 'META', 'TSLA', 'BRK-B', 'UNH', 'JNJ',
            'V', 'PG', 'JPM', 'MA', 'HD', 'CVX', 'MRK', 'ABBV', 'PEP', 'KO',
            'BAC', 'PFE', 'TMO', 'DIS', 'ABT', 'COST', 'DHR', 'NFLX', 'VZ', 'ADBE'
        ][:limit]
        
        data = {}
        failed = []
        
        for symbol in tqdm(symbols, desc="Loading stocks"):
            try:
                ticker = yf.Ticker(symbol)
                hist = ticker.history(period=period)
                if not hist.empty:
                    returns = hist['Close'].pct_change().dropna()
                    if len(returns) > 100:
                        data[symbol] = returns
                    else:
                        failed.append(symbol)
                else:
                    failed.append(symbol)
            except Exception as e:
                failed.append(symbol)
        
        if not data:
            raise ValueError("Failed to load stock data")
        
        df = pd.DataFrame(data)
        df = df.dropna()
        
        self.stock_data = df
        
        df.to_csv(RAW_DATA_DIR / "sp500_returns.csv")
        
        print(f"Loaded {df.shape[1]} stocks, {df.shape[0]} days of data")
        if failed:
            print(f"Failed to load: {failed[:5]}...")
        
        return df
    
    def compute_volatilities(self, window: int = 30) -> pd.Series:
        if self.stock_data is None:
            raise ValueError("Load stock data first")
        
        volatilities = self.stock_data.std() * np.sqrt(252)
        self.volatility_data = volatilities
        
        volatilities.to_csv(RAW_DATA_DIR / "volatilities.csv")
        
        return volatilities
    
    def compute_correlation_matrix(self) -> pd.DataFrame:
        if self.stock_data is None:
            raise ValueError("Load stock data first")
        
        corr = self.stock_data.corr()
        self.correlation_matrix = corr
        
        corr.to_csv(RAW_DATA_DIR / "correlation_matrix.csv")
        
        return corr
    
    def get_market_metrics(self) -> Dict[str, float]:
        if self.stock_data is None:
            return {}
        
        metrics = {
            'market_return': float(self.stock_data.mean().mean() * 252),
            'market_volatility': float(self.stock_data.std().mean() * np.sqrt(252)),
            'avg_correlation': float(self.correlation_matrix.values.mean()) if self.correlation_matrix is not None else 0,
            'num_assets': self.stock_data.shape[1]
        }
        
        return metrics
    
    def download_macro_data(self) -> Dict[str, any]:
        print("Loading macroeconomic data...")
        
        macro_data = {}
        
        try:
            vix = yf.Ticker("^VIX")
            vix_hist = vix.history(period="2y")
            if not vix_hist.empty:
                macro_data['vix'] = vix_hist['Close']
        except:
            print("Failed to load VIX")
        
        try:
            shv = yf.Ticker("SHV")
            shv_hist = shv.history(period="2y")
            if not shv_hist.empty:
                shv_returns = shv_hist['Close'].pct_change().dropna()
                macro_data['risk_free_rate'] = shv_returns.mean() * 252
        except:
            macro_data['risk_free_rate'] = 0.02
        
        return macro_data

loader = RealDataLoader()

