class AgentType(Enum):
    RISK_AVERSE = "averse"
    RISK_NEUTRAL = "neutral"
    RISK_SEEKING = "seeking"

@dataclass
class Agent:
    agent_id: int
    agent_type: AgentType
    risk_aversion: float
    
    portfolio_returns: np.ndarray = field(init=False)
    portfolio_volatilities: np.ndarray = field(init=False)
    asset_weights: np.ndarray = field(init=False)
    asset_names: List[str] = field(init=False)
    
    utility_alone: float = field(init=False)
    utility_in_pool: float = field(default=0.0)
    current_pool_id: Optional[int] = field(default=None)
    
    def __post_init__(self):
        self._initialize_portfolio_from_market()
        self.utility_alone = self.calculate_utility(self.portfolio_returns)
    
    def _initialize_portfolio_from_market(self):
        if stock_returns is None:
            raise ValueError("Market data not loaded")
        
        num_assets = np.random.randint(3, 8)
        available_assets = stock_returns.columns.tolist()
        selected_assets = np.random.choice(available_assets, num_assets, replace=False)
        
        self.asset_names = selected_assets.tolist()
        portfolio_returns_2d = stock_returns[selected_assets].values
        self.portfolio_returns = np.mean(portfolio_returns_2d, axis=1)
        self.portfolio_volatilities = volatilities[selected_assets].values
        self.asset_weights = np.random.dirichlet(np.ones(num_assets))
    
    def calculate_utility(self, returns_array: np.ndarray) -> float:
        if returns_array.size == 0:
            return 0.0
        
        if len(returns_array.shape) == 2:
            portfolio_expected_return = np.mean(returns_array, axis=0).mean()
            portfolio_variance = np.var(returns_array.flatten())
        else:
            portfolio_expected_return = np.mean(returns_array)
            portfolio_variance = np.var(returns_array)
        
        utility = portfolio_expected_return - self.risk_aversion * portfolio_variance
        
        return float(utility)
    
    def update_portfolio_for_shock(self, multiplier: float):
        self.portfolio_returns = (self.portfolio_returns * multiplier).copy()
    
    def get_portfolio_info(self) -> Dict[str, Any]:
        return {
            'id': self.agent_id,
            'type': self.agent_type.value,
            'risk_aversion': self.risk_aversion,
            'assets': self.asset_names,
            'num_assets': len(self.asset_names),
            'utility_alone': float(self.utility_alone),
            'expected_return': float(np.mean(self.portfolio_returns)),
            'volatility': float(np.std(self.portfolio_returns))
        }

@dataclass
class Pool:
    pool_id: int
    members: List[Agent] = field(default_factory=list)
    aggregated_returns: np.ndarray = field(default_factory=lambda: np.array([]))
    
    def __post_init__(self):
        if self.members:
            self._aggregate_assets()
            self._update_member_utilities()
    
    def _aggregate_assets(self) -> None:
        if not self.members:
            self.aggregated_returns = np.array([])
            return
        
        all_returns = [agent.portfolio_returns for agent in self.members]
        self.aggregated_returns = np.vstack(all_returns)
    
    def _update_member_utilities(self) -> None:
        if self.aggregated_returns.size > 0:
            for agent in self.members:
                agent.utility_in_pool = agent.calculate_utility(self.aggregated_returns)
    
    def add_agent(self, agent: Agent, epsilon: float = 0.05) -> bool:
        if agent in self.members:
            return True
        
        if len(self.members) == 0:
            temp_returns = agent.portfolio_returns.reshape(1, -1)
        else:
            temp_returns = np.vstack([self.aggregated_returns, agent.portfolio_returns])
        
        temp_utility = agent.calculate_utility(temp_returns)
        threshold = agent.utility_alone * (1 - epsilon)
        
        if temp_utility >= threshold:
            self.members.append(agent)
            self.aggregated_returns = temp_returns
            agent.current_pool_id = self.pool_id
            self._update_member_utilities()
            return True
        return False
    
    def remove_agent(self, agent: Agent) -> bool:
        if agent in self.members:
            self.members.remove(agent)
            agent.current_pool_id = None
            if self.members:
                self._aggregate_assets()
                self._update_member_utilities()
            else:
                self.aggregated_returns = np.array([])
            return True
        return False
    
    def get_risk(self) -> float:
        if self.aggregated_returns.size == 0:
            return 0.0
        return float(np.var(self.aggregated_returns.flatten()))
    
    def get_return(self) -> float:
        if self.aggregated_returns.size == 0:
            return 0.0
        return float(np.mean(self.aggregated_returns.flatten()))
    
    def get_diversification_benefit(self) -> float:
        if len(self.members) <= 1:
            return 0.0
        
        avg_individual_risk = np.mean([np.var(m.portfolio_returns) for m in self.members])
        pool_risk = self.get_risk()
        
        return (avg_individual_risk - pool_risk) / (avg_individual_risk + 1e-6)
    
    def get_stats(self) -> Dict[str, Any]:
        return {
            'pool_id': self.pool_id,
            'size': len(self.members),
            'risk': self.get_risk(),
            'return': self.get_return(),
            'diversification_benefit': self.get_diversification_benefit(),
            'member_types': [m.agent_type.value for m in self.members]
        }

print("Agent and Pool classes created")

class SparseProtocol:
    def __init__(self, learning_rate: float = 0.1, exploration_rate: float = 0.2):
        self.learning_rate = learning_rate
        self.exploration_rate = exploration_rate
        self.partner_scores = {}
        
    def compute_marginal_gain(self, agent: Agent, pool: Pool) -> float:
        if not pool.members:
            return 0.0
        
        current_utility = agent.utility_in_pool if agent.current_pool_id == pool.pool_id else agent.utility_alone
        
        if len(pool.members) == 0:
            temp_returns = agent.portfolio_returns.reshape(1, -1)
        else:
            temp_returns = np.vstack([pool.aggregated_returns, agent.portfolio_returns])
        
        new_utility = agent.calculate_utility(temp_returns)
        
        return new_utility - current_utility
    
    def find_best_pool(self, agent: Agent, pools: List[Pool]) -> Optional[Pool]:
        best_gain = -float('inf')
        best_pool = None
        
        for pool in pools:
            gain = self.compute_marginal_gain(agent, pool)
            if gain > best_gain and gain > 0:
                best_gain = gain
                best_pool = pool
        
        return best_pool
    
    def should_create_pool(self, agent: Agent, other_agents: List[Agent]) -> bool:
        if not other_agents:
            return False
        
        for other in other_agents:
            temp_pool = Pool(pool_id=-1, members=[agent])
            if temp_pool.add_agent(other, epsilon=0.1):
                return True
        
        return np.random.random() < self.exploration_rate
    
    def update_partner_scores(self, agent_i: int, agent_j: int, success: bool):
        if agent_i not in self.partner_scores:
            self.partner_scores[agent_i] = {}
        
        old_score = self.partner_scores[agent_i].get(agent_j, 0.5)
        delta = self.learning_rate * (1.0 if success else -0.5)
        new_score = np.clip(old_score + delta, 0.0, 1.0)
        self.partner_scores[agent_i][agent_j] = new_score

class SimulationMode(Enum):
    NO_POOLING = "no_pooling"
    RANDOM_POOLING = "random_pooling"
    SPARSE = "sparse"

@dataclass
class SimulationConfig:
    num_agents: int = 30
    num_iterations: int = 80
    shock_iteration: int = 40
    shock_multiplier: float = 1.8
    
    risk_params: Dict[AgentType, float] = field(default_factory=lambda: {
        AgentType.RISK_AVERSE: 2.5,
        AgentType.RISK_NEUTRAL: 1.0,
        AgentType.RISK_SEEKING: 0.2
    })
    
    epsilon: float = 0.05
    learning_rate: float = 0.1
    exploration_rate: float = 0.15

@dataclass
class Metrics:
    total_utility: List[float] = field(default_factory=list)
    system_risk: List[float] = field(default_factory=list)
    num_pools: List[int] = field(default_factory=list)
    avg_pool_size: List[float] = field(default_factory=list)
    efficiency: List[float] = field(default_factory=list)
    stability: List[float] = field(default_factory=list)
    diversification_benefit: List[float] = field(default_factory=list)

class Simulation:
    def __init__(self, config: SimulationConfig):
        self.config = config
        self.agents: List[Agent] = []
        self.pools: List[Pool] = []
        self.protocol = SparseProtocol(
            learning_rate=config.learning_rate,
            exploration_rate=config.exploration_rate
        )
        self.metrics = Metrics()
        self._initialize_agents()
    
    def _initialize_agents(self) -> None:
        self.agents = []
        
        for i in range(self.config.num_agents):
            agent_type = list(AgentType)[i % len(AgentType)]
            agent = Agent(
                agent_id=i,
                agent_type=agent_type,
                risk_aversion=self.config.risk_params[agent_type]
            )
            self.agents.append(agent)
        
        print(f"Created {len(self.agents)} agents")
    
    def _calculate_metrics(self) -> Tuple[float, float, int, float, float, float, float]:
        total_utility = sum(
            agent.utility_in_pool if agent.utility_in_pool > 0 else agent.utility_alone
            for agent in self.agents
        )
        
        pool_risk = sum(pool.get_risk() for pool in self.pools)
        lone_agents = [
            agent for agent in self.agents
            if not any(agent in pool.members for pool in self.pools)
        ]
        lone_risk = sum(np.var(agent.portfolio_returns) for agent in lone_agents)
        system_risk = pool_risk + lone_risk
        
        num_pools = len(self.pools)
        avg_pool_size = np.mean([len(pool.members) for pool in self.pools]) if num_pools > 0 else 0.0
        
        efficiency = total_utility / (system_risk + 1e-6)
        
        if len(self.metrics.total_utility) >= 5:
            recent_utils = self.metrics.total_utility[-5:]
            stability = 1 - (np.std(recent_utils) / (np.mean(recent_utils) + 1e-10))
        else:
            stability = 1.0
        
        diversification_benefit = np.mean([
            pool.get_diversification_benefit() for pool in self.pools
        ]) if self.pools else 0.0
        
        return total_utility, system_risk, num_pools, avg_pool_size, efficiency, stability, diversification_benefit
    
    def _apply_shock(self) -> None:
        for agent in self.agents:
            agent.update_portfolio_for_shock(self.config.shock_multiplier)
            agent.utility_alone = agent.calculate_utility(agent.portfolio_returns)
        
        for pool in self.pools:
            pool._aggregate_assets()
            pool._update_member_utilities()
    
    def simulate_no_pooling(self) -> Metrics:
        print("Mode: No Pooling (baseline)")
        
        for iteration in tqdm(range(self.config.num_iterations), desc="Simulation"):
            total_utility = sum(agent.utility_alone for agent in self.agents)
            system_risk = sum(np.var(agent.portfolio_returns) for agent in self.agents)
            efficiency = total_utility / (system_risk + 1e-6)
            
            self.metrics.total_utility.append(total_utility)
            self.metrics.system_risk.append(system_risk)
            self.metrics.num_pools.append(0)
            self.metrics.avg_pool_size.append(0.0)
            self.metrics.efficiency.append(efficiency)
            self.metrics.stability.append(1.0)
            self.metrics.diversification_benefit.append(0.0)
            
            if iteration == self.config.shock_iteration:
                self._apply_shock()
        
        return self.metrics
    
    def simulate_random_pooling(self) -> Metrics:
        print("Mode: Random Pooling")
        
        for iteration in tqdm(range(self.config.num_iterations), desc="Simulation"):
            shuffled_agents = self.agents.copy()
            np.random.shuffle(shuffled_agents)
            
            pool_size = np.random.randint(3, min(8, len(shuffled_agents) // 3 + 1))
            
            self.pools = []
            for i in range(0, len(shuffled_agents), pool_size):
                group = shuffled_agents[i:i+pool_size]
                if len(group) > 1:
                    pool = Pool(pool_id=len(self.pools), members=[group[0]])
                    for agent in group[1:]:
                        pool.add_agent(agent, epsilon=self.config.epsilon)
                    if len(pool.members) > 1:
                        self.pools.append(pool)
            
            metrics_values = self._calculate_metrics()
            self.metrics.total_utility.append(metrics_values[0])
            self.metrics.system_risk.append(metrics_values[1])
            self.metrics.num_pools.append(metrics_values[2])
            self.metrics.avg_pool_size.append(metrics_values[3])
            self.metrics.efficiency.append(metrics_values[4])
            self.metrics.stability.append(metrics_values[5])
            self.metrics.diversification_benefit.append(metrics_values[6])
            
            if iteration == self.config.shock_iteration:
                self._apply_shock()
        
        return self.metrics
    
    def simulate_sparse(self) -> Metrics:
        print("Mode: SPARSE (smart protocol)")
        
        next_pool_id = 0
        
        for iteration in tqdm(range(self.config.num_iterations), desc="Simulation"):
            agents_to_process = self.agents.copy()
            for agent in agents_to_process:
                best_pool = self.protocol.find_best_pool(agent, self.pools)
                
                if best_pool and best_pool.add_agent(agent, epsilon=self.config.epsilon):
                    if best_pool.members:
                        self.protocol.update_partner_scores(agent.agent_id, best_pool.members[0].agent_id, True)
                elif self.protocol.should_create_pool(agent, [a for a in self.agents if a != agent]):
                    other_agents = [a for a in self.agents if a != agent and a.current_pool_id is None]
                    if other_agents:
                        other = np.random.choice(other_agents)
                        new_pool = Pool(pool_id=next_pool_id, members=[agent])
                        
                        if new_pool.add_agent(other, epsilon=self.config.epsilon):
                            self.pools.append(new_pool)
                            next_pool_id += 1
                            self.protocol.update_partner_scores(agent.agent_id, other.agent_id, True)
            
            self.pools = [pool for pool in self.pools if len(pool.members) > 1]
            
            metrics_values = self._calculate_metrics()
            self.metrics.total_utility.append(metrics_values[0])
            self.metrics.system_risk.append(metrics_values[1])
            self.metrics.num_pools.append(metrics_values[2])
            self.metrics.avg_pool_size.append(metrics_values[3])
            self.metrics.efficiency.append(metrics_values[4])
            self.metrics.stability.append(metrics_values[5])
            self.metrics.diversification_benefit.append(metrics_values[6])
            
            if iteration == self.config.shock_iteration:
                self._apply_shock()
        
        return self.metrics

print("SPARSE protocol and Simulation class created")

def run_scaled_experiment(num_agents_list: List[int] = [30, 50], num_seeds: int = 3) -> Dict[str, Any]:
    results = {}
    
    for num_agents in num_agents_list:
        print("\n" + "="*70)
        print(f"EXPERIMENT WITH {num_agents} AGENTS")
        print("="*70)
        
        config = SimulationConfig(
            num_agents=num_agents,
            num_iterations=80,
            shock_iteration=40,
            shock_multiplier=1.8
        )
        
        mode_results = {
            'no_pooling': [],
            'random_pooling': [],
            'sparse': []
        }
        
        for seed in range(num_seeds):
            print(f"\n  Seed {seed + 1}/{num_seeds}")
            np.random.seed(42 + seed)
            
            for mode in [SimulationMode.NO_POOLING, SimulationMode.RANDOM_POOLING, SimulationMode.SPARSE]:
                sim = Simulation(config)
                
                if mode == SimulationMode.NO_POOLING:
                    metrics = sim.simulate_no_pooling()
                elif mode == SimulationMode.RANDOM_POOLING:
                    metrics = sim.simulate_random_pooling()
                else:
                    metrics = sim.simulate_sparse()
                
                mode_results[mode.value].append(metrics)
        
        results[num_agents] = mode_results
        
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        results_file = RESULTS_DIR / f"experiment_results_{num_agents}_{timestamp}.json"
        
        serializable_results = {}
        for n_agents, mode_data in results.items():
            serializable_results[str(n_agents)] = {}
            for mode, metrics_list in mode_data.items():
                serializable_results[str(n_agents)][mode] = []
                for metrics in metrics_list:
                    serializable_results[str(n_agents)][mode].append({
                        'total_utility': metrics.total_utility,
                        'system_risk': metrics.system_risk,
                        'num_pools': metrics.num_pools,
                        'avg_pool_size': metrics.avg_pool_size,
                        'efficiency': metrics.efficiency,
                        'stability': metrics.stability,
                        'diversification_benefit': metrics.diversification_benefit
                    })
        
        with open(results_file, 'w') as f:
            json.dump(serializable_results, f, indent=2)
        
        print(f"\nResults saved: {results_file}")
    
    return results

def plot_comparison_results(results: Dict, save: bool = True):
    colors = {
        'no_pooling': '#e74c3c',
        'random_pooling': '#3498db',
        'sparse': '#2ecc71'
    }
    
    labels = {
        'no_pooling': 'No Pooling',
        'random_pooling': 'Random Pooling',
        'sparse': 'SPARSE'
    }
    
    for num_agents, mode_data in results.items():
        print(f"\nGenerating plots for {num_agents} agents...")
        
        fig, axes = plt.subplots(2, 3, figsize=(18, 10))
        fig.suptitle(f'Pooling Protocol Comparison\n{num_agents} agents, real financial data', 
                     fontsize=16, fontweight='bold')
        
        metrics_to_plot = [
            ('efficiency', 'Efficiency (Utility/Risk)', axes[0, 0]),
            ('system_risk', 'Systemic Risk', axes[0, 1]),
            ('total_utility', 'Total Utility', axes[0, 2]),
            ('num_pools', 'Number of Pools', axes[1, 0]),
            ('avg_pool_size', 'Average Pool Size', axes[1, 1]),
            ('diversification_benefit', 'Diversification Benefit', axes[1, 2])
        ]
        
        for mode, metrics_list in mode_data.items():
            avg_metrics = {}
            for metric_name in ['total_utility', 'system_risk', 'num_pools', 'avg_pool_size', 
                               'efficiency', 'stability', 'diversification_benefit']:
                values = [getattr(m, metric_name) for m in metrics_list]
                avg_metrics[metric_name] = np.mean(values, axis=0)
            
            for metric_name, metric_label, ax in metrics_to_plot:
                ax.plot(avg_metrics[metric_name], 
                       label=labels[mode], 
                       color=colors[mode], 
                       linewidth=2)
                ax.set_xlabel('Iteration', fontsize=10)
                ax.set_ylabel(metric_label, fontsize=10)
                ax.axvline(x=40, color='red', linestyle='--', alpha=0.7, label='Market Shock')
                ax.grid(True, alpha=0.3)
                ax.legend(loc='best', fontsize=8)
        
        plt.tight_layout()
        if save:
            plt.savefig(PLOTS_DIR / f'comparison_{num_agents}_agents.pdf', dpi=300, bbox_inches='tight')
        plt.show()
    
    return

def print_statistical_summary(results: Dict):
    print("\n" + "="*80)
    print("STATISTICAL ANALYSIS OF RESULTS")
    print("="*80)
    
    for num_agents, mode_data in results.items():
        print(f"\n{num_agents} AGENTS:")
        print("-" * 50)
        
        sparse_metrics = mode_data['sparse']
        random_metrics = mode_data['random_pooling']
        no_pooling_metrics = mode_data['no_pooling']
        
        sparse_final_eff = np.mean([np.mean(m.efficiency[-10:]) for m in sparse_metrics])
        random_final_eff = np.mean([np.mean(m.efficiency[-10:]) for m in random_metrics])
        no_pooling_final_eff = np.mean([np.mean(m.efficiency[-10:]) for m in no_pooling_metrics])
        
        sparse_final_risk = np.mean([np.mean(m.system_risk[-10:]) for m in sparse_metrics])
        no_pooling_final_risk = np.mean([np.mean(m.system_risk[-10:]) for m in no_pooling_metrics])
        
        print(f"  SPARSE vs Random efficiency: {(sparse_final_eff/random_final_eff - 1)*100:+.1f}%")
        print(f"  SPARSE vs No Pooling efficiency: {(sparse_final_eff/no_pooling_final_eff - 1)*100:+.1f}%")
        print(f"  Risk reduction (SPARSE vs No Pooling): {(1 - sparse_final_risk/no_pooling_final_risk)*100:+.1f}%")
        
        sparse_div_benefit = np.mean([np.mean(m.diversification_benefit[-10:]) for m in sparse_metrics])
        random_div_benefit = np.mean([np.mean(m.diversification_benefit[-10:]) for m in random_metrics])
        print(f"  Diversification benefit: SPARSE={sparse_div_benefit:.3f}, Random={random_div_benefit:.3f}")
        
        sparse_stability = np.mean([np.mean(m.stability[-10:]) for m in sparse_metrics])
        random_stability = np.mean([np.mean(m.stability[-10:]) for m in random_metrics])
        no_pooling_stability = np.mean([np.mean(m.stability[-10:]) for m in no_pooling_metrics])
        print(f"  Stability: SPARSE={sparse_stability:.3f}, Random={random_stability:.3f}, No Pooling={no_pooling_stability:.3f}")

print("\n" + "="*70)
print("RUNNING SCALABLE EXPERIMENTS")
print("="*70)

results = run_scaled_experiment(num_agents_list=[30, 50], num_seeds=2)

print("\n" + "="*70)
print("ALL EXPERIMENTS COMPLETED")
print("="*70)

plot_comparison_results(results, save=True)

print_statistical_summary(results)

timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
report_file = RESULTS_DIR / f"experiment_report_{timestamp}.txt"

with open(report_file, 'w') as f:
    f.write("SPARSE EXPERIMENT REPORT\n")
    f.write("="*80 + "\n")
    f.write(f"Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
    f.write(f"Number of agents: {list(results.keys())}\n")
    f.write(f"Number of seeds: 2\n\n")
    f.write("RESULTS:\n")
    for num_agents, mode_data in results.items():
        f.write(f"\n{num_agents} AGENTS:\n")
        sparse_metrics = mode_data['sparse']
        random_metrics = mode_data['random_pooling']
        no_pooling_metrics = mode_data['no_pooling']
        
        sparse_final_eff = np.mean([np.mean(m.efficiency[-10:]) for m in sparse_metrics])
        random_final_eff = np.mean([np.mean(m.efficiency[-10:]) for m in random_metrics])
        no_pooling_final_eff = np.mean([np.mean(m.efficiency[-10:]) for m in no_pooling_metrics])
        
        f.write(f"  SPARSE efficiency: {sparse_final_eff:.4f}\n")
        f.write(f"  Improvement vs Random: {(sparse_final_eff/random_final_eff - 1)*100:+.1f}%\n")
        f.write(f"  Improvement vs No Pooling: {(sparse_final_eff/no_pooling_final_eff - 1)*100:+.1f}%\n")

print(f"\nReport saved: {report_file}")
